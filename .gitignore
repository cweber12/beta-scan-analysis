.venv/
__pycache__/
*.pyc
*.pt
downloads/

# Derived analysis outputs (report.html + features CSVs).
reports/

# Video binaries live inside the analysis bundle, but stay out of git; the
# metadata.json / final_frame.png / detections/ record is still tracked.
analysis/**/*.mp4
analysis/**/*.mov
analysis/**/*.mkv
analysis/**/*.webm
analysis/**/*.avi

# Flagged-frame crop thumbnails (issue #44): derived from the gitignored video
# binary, referenced by path in the eval record — the JSON record stays tracked,
# the PNGs do not (same rule as the video binaries above).
analysis/**/crops/
